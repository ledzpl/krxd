+}
+
+@media (max-width: 980px) {
+  .summaryBand,
+  .signals,
+  .sections {
+    grid-template-columns: 1fr;
+  }
+}
+
+@media (max-width: 640px) {
+  .page {
+    padding-inline: 14px;
+  }
