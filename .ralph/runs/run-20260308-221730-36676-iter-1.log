]);

const input = page.getByLabel(\"Stock code\");
await input.fill(\"123\");
await page.getByRole(\"button\", { name: /Preview dashboard/i }).click();
const invalidFeedback = await page.getByText(/Enter exactly six numeric digits/i).textContent();

await input.fill(\"005930\");
await page.getByRole(\"button\", { name: /Preview dashboard/i }).click();
const validFeedback = await page.getByText(/Stock code 005930 is queued/i).textContent();

await page.screenshot({ path: \"tmp/us-001-home.png\", fullPage: true });

console.log(JSON.stringify({
  title: await page.title(),
  url: page.url(),
  headingVisible: await heading.isVisible(),
  placeholderChecks,
  invalidFeedback,
  validFeedback,
  screenshot: \"tmp/us-001-home.png\"
}, null, 2));

await client.disconnect();
