+.page {
+  min-height: 100vh;
+  padding: 32px 20px 72px;
+}
+
+.frame {
+  width: min(1180px, 100%);
+  margin: 0 auto;
+  display: grid;
+  gap: 24px;
+}
+
+.hero {
