+}
+
+.grid {
+  display: grid;
+  gap: 24px;
+}
+
+.summaryBand {
+  display: grid;
+  gap: 16px;
+  grid-template-columns: 1.2fr repeat(4, minmax(0, 1fr));
+}
+
+.card {
